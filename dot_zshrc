# ---------- Custom Functions ----------

# Claude Code 許可ディレクトリ
# - 末尾 "/" あり: そのディレクトリ配下のみ許可（ディレクトリ自身は不可）
# - 末尾 "/" なし: そのディレクトリ自身および配下を許可
claude_allowed_dirs=(
  "${HOME}/src/"
  "${HOME}/.local/share/chezmoi"
)

claude() {
  local current_dir
  current_dir=$(pwd)
  for dir in "${claude_allowed_dirs[@]}"; do
    if [[ "$dir" == */ ]]; then
      [[ "$current_dir" == "$dir"* ]] && { command claude "$@"; return; }
    else
      [[ "$current_dir" == "$dir" || "$current_dir" == "$dir"/* ]] && { command claude "$@"; return; }
    fi
  done
  echo $'\e[1;33mWARNING:\e[0m Claude Code is not intended to be launched in this directory!'
  read "?Are you sure you want to continue? (y/n): " answer
  [ "$answer" = 'y' ] || { echo 'Aborted.'; return; }
  command claude "$@"
}
