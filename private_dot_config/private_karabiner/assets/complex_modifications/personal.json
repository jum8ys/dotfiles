{
  "title": "Personal",
  "rules": [
    {
      "description": "[built in keyboard only] コマンドキーを単体で押したときに、英数・かなキーを送信する。（左コマンドキーは英数、右コマンドキーはかな） (rev 3)",
      "manipulators": [
        {
          "conditions": [
            {
              "identifiers": [{ "is_built_in_keyboard": true }],
              "type": "device_if"
            }
          ],
          "from": {
            "key_code": "left_command",
            "modifiers": { "optional": ["any"] }
          },
          "parameters": { "basic.to_if_held_down_threshold_milliseconds": 100 },
          "to": [
            {
              "key_code": "left_command",
              "lazy": true
            }
          ],
          "to_if_alone": [{ "key_code": "japanese_eisuu" }],
          "to_if_held_down": [{ "key_code": "left_command" }],
          "type": "basic"
        },
        {
          "conditions": [
            {
              "identifiers": [{ "is_built_in_keyboard": true }],
              "type": "device_if"
            }
          ],
          "from": {
            "key_code": "right_command",
            "modifiers": { "optional": ["any"] }
          },
          "parameters": { "basic.to_if_held_down_threshold_milliseconds": 100 },
          "to": [
            {
              "key_code": "right_command",
              "lazy": true
            }
          ],
          "to_if_alone": [{ "key_code": "japanese_kana" }],
          "to_if_held_down": [{ "key_code": "right_command" }],
          "type": "basic"
        }
      ]
    },
    {
      "description": "Double tap left/right control to toggle Ghostty",
      "manipulators": [
        {
          "conditions": [
            {
              "name": "left_control_tapped",
              "type": "variable_if",
              "value": 1
            }
          ],
          "from": {
            "key_code": "left_control",
            "modifiers": { "optional": ["caps_lock"] }
          },
          "to": [
            {
              "key_code": "left_control",
              "lazy": true
            }
          ],
          "to_if_alone": [
            { "shell_command": "~/.config/karabiner/toggle-ghostty" }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "left_control",
            "modifiers": { "optional": ["caps_lock"] }
          },
          "parameters": { "basic.to_delayed_action_delay_milliseconds": 300 },
          "to": [
            {
              "set_variable": {
                "name": "left_control_tapped",
                "value": 1
              }
            },
            {
              "key_code": "left_control",
              "lazy": true
            }
          ],
          "to_delayed_action": {
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "left_control_tapped",
                  "value": 0
                }
              }
            ],
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "left_control_tapped",
                  "value": 0
                }
              }
            ]
          },
          "type": "basic"
        },
        {
          "conditions": [
            {
              "name": "right_control_tapped",
              "type": "variable_if",
              "value": 1
            }
          ],
          "from": {
            "key_code": "right_control",
            "modifiers": { "optional": ["caps_lock"] }
          },
          "to": [
            {
              "key_code": "right_control",
              "lazy": true
            }
          ],
          "to_if_alone": [
            { "shell_command": "~/.config/karabiner/toggle-ghostty" }
          ],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "right_control",
            "modifiers": { "optional": ["caps_lock"] }
          },
          "parameters": { "basic.to_delayed_action_delay_milliseconds": 300 },
          "to": [
            {
              "set_variable": {
                "name": "right_control_tapped",
                "value": 1
              }
            },
            {
              "key_code": "right_control",
              "lazy": true
            }
          ],
          "to_delayed_action": {
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "right_control_tapped",
                  "value": 0
                }
              }
            ],
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "right_control_tapped",
                  "value": 0
                }
              }
            ]
          },
          "type": "basic"
        }
      ]
    }
  ]
}
